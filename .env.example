# Kachu v2 環境變數範本
# 複製為 .env 後填入實際值

# ── LINE Bot ──────────────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_BOSS_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AgentOS ───────────────────────────────────────────────────────────────────
AGENTOS_BASE_URL=http://localhost:8000

# ── Kachu service（自身 URL，供 AgentOS KachuAdapter 呼叫）─────────────────────
KACHU_BASE_URL=http://localhost:8001

# ── 資料庫 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://kachu:kachu@localhost:5432/kachu

# ── LLM ──────────────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
LITELLM_MODEL=gemini/gemini-2.0-flash

# ── Google Business Profile ───────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/google-service-account.json
GOOGLE_BUSINESS_ACCOUNT_ID=accounts/your_account_id
GOOGLE_BUSINESS_LOCATION_ID=locations/your_location_id
GOOGLE_WEBHOOK_SHARED_SECRET=replace_with_shared_secret

# ── 服務設定 ──────────────────────────────────────────────────────────────────
APP_ENV=development
